{
  "version": 2,
  "buildCommand": "cd backend && python manage.py migrate --noinput",
  "builds": [
    {
      "src": "backend/little_fingers/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "backend/little_fingers/wsgi.py"
    }
  ]
}
